{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID" },
        "sellerId": { "type": "string", "description": "Unique Seller ID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User role" },
        "subscriptionPlan": { "type": "string", "enum": ["free", "pro"], "description": "Subscription plan" },
        "activePlanId": { "type": "string", "description": "ID of the active subscription plan" },
        "subscriptionDate": { "type": "string", "format": "date-time", "description": "Date when the subscription was activated" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["uid", "email", "role", "subscriptionPlan", "createdAt"]
    },
    "AdminMsg": {
      "title": "AdminMsg",
      "description": "Broadcast messages from admin",
      "type": "object",
      "properties": {
        "content": { "type": "string", "description": "Message content" },
        "target": { "type": "string", "enum": ["ALL", "PRO", "TRIAL"], "description": "Target audience" },
        "active": { "type": "boolean", "description": "Whether the message is active" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["content", "target", "active", "createdAt"]
    },
    "DailyStats": {
      "title": "DailyStats",
      "description": "Daily usage statistics for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "User ID" },
        "date": { "type": "string", "format": "date", "description": "Date" },
        "listingsGenerated": { "type": "number", "description": "Number of listings generated" },
        "whiteBackgrounds": { "type": "number", "description": "Number of white backgrounds generated" },
        "marketAnalysis": { "type": "number", "description": "Number of market analysis generated" },
        "aplusGenerated": { "type": "number", "description": "Number of A+ content generated" },
        "photoshoots": { "type": "number", "description": "Number of AI photoshoots generated" },
        "shippingOptimizations": { "type": "number", "description": "Number of shipping optimizations performed" }
      },
      "required": ["userId", "date", "listingsGenerated", "whiteBackgrounds", "marketAnalysis", "aplusGenerated", "photoshoots", "shippingOptimizations"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/users/{userId}/daily_stats/{date}": {
      "schema": "DailyStats",
      "description": "Daily usage statistics"
    },
    "/AdminMsg/{msgId}": {
      "schema": "AdminMsg",
      "description": "Admin broadcast messages"
    }
  }
}
