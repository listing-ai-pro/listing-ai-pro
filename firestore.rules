rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Domain Validators
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'subscriptionPlan', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['user', 'admin'] &&
             data.subscriptionPlan in ['free', 'pro'] &&
             data.createdAt is timestamp;
    }

    function isValidDailyStats(data) {
      return data.keys().hasAll(['userId', 'date', 'listingsGenerated', 'imagesGenerated', 'marketAnalysis', 'aplusGenerated']) &&
             data.userId is string &&
             data.date is string &&
             data.listingsGenerated is number &&
             data.imagesGenerated is number &&
             data.marketAnalysis is number &&
             data.aplusGenerated is number;
    }

    // Collections
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.uid == resource.data.uid;
    }

    match /users/{userId}/daily_stats/{date} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidDailyStats(request.resource.data);
      allow update: if isOwner(userId) && isValidDailyStats(request.resource.data);
    }
  }
}
